pico-8 cartridge // http://www.pico-8.com
version 29
__lua__
--game loop

function _init()
	p=init_player()
	w=init_world()
end

function _update()
	cls()
	if(btn(0)) then
		p.x-=1
		anim(p,2,2,20,true)
	elseif(btn(1)) then
		p.x+=1
		anim(p,2,2,20)
	else 
		spr(1,p.x,p.y)
	end
end

function _draw()
end
-->8
-- global vars and inits

function init_player()
	p={
		sp=1,
		x=63,
		y=63,
		w=8,
		h=8,
		flp=false,
		dx=0,
		dy=0,
		max_dx=2,
		max_dy=3,
		acc=0.5,
		boost=4,
		anim=0,
		running=false,
		jumping=false,
		falling=false
	}
	return p
end

function init_world()
	w={
		g=0.3,
		mu=0.85
	}
	return w
end


-->8
-- player
function player_update()
	-- physics
	p.dy+=w.g
	p.dx*=w.mu
end


function anim(o,sf,nf,sp,fl)
  if(not o.a_ct) o.a_ct=0
  if(not o.a_st) o.a_st=0

  o.a_ct+=1

  if(o.a_ct%(30/sp)==0) then
    o.a_st+=1
    if(o.a_st==nf) o.a_st=0
  end

  o.a_fr=sf+o.a_st
  spr(o.a_fr,o.x,o.y,1,1,fl)
end
