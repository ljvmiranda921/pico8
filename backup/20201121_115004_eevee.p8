pico-8 cartridge // http://www.pico-8.com
version 29
__lua__
--game loop

function _init()
	p=init_player()
	w=init_world()
end

function _update()
	player_update()
end

function _draw()
	cls()
	map(0,0)
	spr(p.sp,p.x,p.y)
end
-->8
-- global vars and inits

function init_player()
	p={
		sp=1,
		-- pos
		x=63,
		y=63,
		w=8,
		h=8,
		flp=false,
		-- movement
		dx=0,
		dy=0,
		max_dx=2,
		max_dy=3,
		acc=0.5,
		boost=4,
		anim=0,
		-- action states
		running=false,
		jumping=false,
		falling=false,
		sliding=false,
		-- interact states
		landed=false
	}
	return p
end

function init_world()
	w={
		g=0.3,
		mu=0.85
	}
	return w
end


-->8
-- player
function player_update()
	-- physics
	p.dy+=w.g
	p.dx*=w.mu
	
	-- running
	if btn(⬅️) then
		p.dx-=p.acc
		p.running=true
		p.flp=true
	end
	
	if btn(➡️) then
		p.dx+=p.acc
		p.running=true
		p.flp=false
	end
	
	--slide
	if p.running
	and not btn(⬅️)
	and not btn(➡️)
	and not p.falling
	and not p.jumping then
		p.running=false
		p.sliding=true
	end

	--jump	
	if btnp(❎) and p.landed then
		p.dy-=p.boost
		p.landed=false
	end
	
	p.x+=p.dx
	p.y+=p.dy
end


function anim(o,sf,nf,sp,fl)
  if(not o.a_ct) o.a_ct=0
  if(not o.a_st) o.a_st=0

  o.a_ct+=1

  if(o.a_ct%(30/sp)==0) then
    o.a_st+=1
    if(o.a_st==nf) o.a_st=0
  end

  o.a_fr=sf+o.a_st
  spr(o.a_fr,o.x,o.y,1,1,fl)
end
